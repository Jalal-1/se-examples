{
  "$schema": "../../schemas/example-manifest.schema.json",
  "schemaVersion": 2,
  "id": "ownable-counter",
  "displayName": "Ownable Counter",
  "description": "An unshielded counter whose state-changing circuit is restricted by OpenZeppelin Ownable.",
  "requires": ["compact-contracts", "shielded-state", "unshielded-state"],
  "toolchains": {
    "v1-stable": {
      "source": "contract/ownable-counter.compact",
      "openzeppelin": {
        "package": "@openzeppelin/compact-contracts",
        "version": "0.3.0-alpha"
      }
    },
    "v2-rc": {
      "source": "contract/ownable-counter.compact",
      "openzeppelin": {
        "package": "@openzeppelin/compact-contracts",
        "version": "0.3.0-alpha"
      }
    }
  }
}
