{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jalal-1/se-examples/schemas/network-profile.schema.json",
  "title": "se-examples network profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "displayName",
    "mode",
    "status",
    "compatibilityLine",
    "networkId",
    "endpoints",
    "runtime",
    "components",
    "capabilities",
    "sources"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "displayName": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["local", "hosted", "observer"] },
    "status": { "enum": ["active", "planned", "retired"] },
    "compatibilityLine": { "enum": ["v1-stable", "v2-rc"] },
    "networkId": { "type": "string", "minLength": 1 },
    "endpoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "indexer", "indexerWs", "proofServer"],
      "properties": {
        "node": { "type": "string", "format": "uri" },
        "nodeWs": { "type": "string", "format": "uri" },
        "indexer": { "type": "string", "format": "uri" },
        "indexerWs": { "type": "string", "format": "uri" },
        "proofServer": { "type": "string", "format": "uri" },
        "faucet": { "type": "string", "format": "uri" },
        "explorer": { "type": "string", "format": "uri" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specName", "specVersion", "transactionVersion"],
      "properties": {
        "specName": { "type": "string", "minLength": 1 },
        "specVersion": { "type": "integer", "minimum": 0 },
        "transactionVersion": { "type": "integer", "minimum": 0 }
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node",
        "indexer",
        "proofServer",
        "compactCompiler",
        "compactRuntime",
        "compactJs",
        "midnightJs",
        "walletSdk",
        "ledger"
      ],
      "properties": {
        "node": { "$ref": "#/$defs/component" },
        "indexer": { "$ref": "#/$defs/component" },
        "proofServer": { "$ref": "#/$defs/component" },
        "compactDevtools": { "$ref": "#/$defs/component" },
        "compactCompiler": { "$ref": "#/$defs/component" },
        "compactRuntime": { "$ref": "#/$defs/component" },
        "compactJs": { "$ref": "#/$defs/component" },
        "platformJs": { "$ref": "#/$defs/component" },
        "onchainRuntime": { "$ref": "#/$defs/component" },
        "midnightJs": { "$ref": "#/$defs/component" },
        "httpClientProofProvider": { "$ref": "#/$defs/component" },
        "indexerPublicDataProvider": { "$ref": "#/$defs/component" },
        "nodeZkConfigProvider": { "$ref": "#/$defs/component" },
        "walletSdk": { "$ref": "#/$defs/component" },
        "testkitJs": { "$ref": "#/$defs/component" },
        "dappConnector": { "$ref": "#/$defs/component" },
        "ledger": { "$ref": "#/$defs/component" },
        "openzeppelinCompact": { "$ref": "#/$defs/component" }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uri" },
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "image": { "type": "string", "minLength": 1 },
        "package": { "type": "string", "minLength": 1 },
        "location": { "enum": ["local", "remote", "build-time"] }
      }
    }
  }
}
