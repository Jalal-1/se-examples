{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jalal-1/se-examples/schemas/example-manifest.schema.json",
  "title": "se-examples example manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "displayName",
    "requires",
    "toolchains"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "requires": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "toolchains": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "v1-stable": { "$ref": "#/$defs/toolchainTarget" },
        "v2-rc": { "$ref": "#/$defs/toolchainTarget" }
      }
    }
  },
  "$defs": {
    "toolchainTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "openzeppelin"],
      "properties": {
        "source": { "type": "string", "pattern": "^contract/.+\\.compact$" },
        "openzeppelin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["package", "version"],
          "properties": {
            "package": { "const": "@openzeppelin/compact-contracts" },
            "version": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
