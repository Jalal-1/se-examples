{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jalal-1/se-examples/schemas/example-manifest.schema.json",
  "title": "se-examples example manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "displayName",
    "toolchainLine",
    "networks",
    "requires"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "toolchainLine": { "enum": ["v1-stable", "v2-rc"] },
    "networks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "requires": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "openzeppelin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "version"],
      "properties": {
        "package": { "const": "@openzeppelin/compact-contracts" },
        "version": { "type": "string", "minLength": 1 }
      }
    }
  }
}
