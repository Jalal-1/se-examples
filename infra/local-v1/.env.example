# Public, non-production defaults for the local-v1 development network.
COMPOSE_PROJECT_NAME=se-examples-local-v1

MIDNIGHT_NODE_IMAGE=midnightntwrk/midnight-node:1.0.0
MIDNIGHT_INDEXER_IMAGE=midnightntwrk/indexer-standalone:4.3.3
MIDNIGHT_PROOF_SERVER_IMAGE=midnightntwrk/proof-server:8.1.0

MIDNIGHT_NODE_PORT=9944
MIDNIGHT_INDEXER_PORT=8088
MIDNIGHT_PROOF_SERVER_PORT=6300

MIDNIGHT_NETWORK_ID=undeployed
MIDNIGHT_EXPECTED_SPEC_VERSION=1000000
MIDNIGHT_EXPECTED_TRANSACTION_VERSION=3
MIDNIGHT_EXPECTED_PROOF_SERVER_VERSION=8.1.0

# Deterministic local-development value from the official standalone stack.
# It is intentionally public and must never be reused outside local testing.
MIDNIGHT_INDEXER_DEV_SECRET=303132333435363738393031323334353637383930313233343536373839303132
