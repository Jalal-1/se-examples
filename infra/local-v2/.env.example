# Public, non-production defaults for the local-v2 RC development network.
COMPOSE_PROJECT_NAME=se-examples-local-v2

MIDNIGHT_NODE_IMAGE=midnightntwrk/midnight-node:2.0.0-rc.4
MIDNIGHT_INDEXER_IMAGE=midnightntwrk/indexer-standalone:4.4.0-pre-alpha.16-l91r3-n2r3-bridge-and-events-epics-contract-zswap-16c656df
MIDNIGHT_PROOF_SERVER_IMAGE=midnightntwrk/proof-server:9.0.0-rc.5_experimental

MIDNIGHT_NODE_PORT=9944
MIDNIGHT_INDEXER_PORT=8088
MIDNIGHT_PROOF_SERVER_PORT=6300

MIDNIGHT_NETWORK_ID=undeployed
MIDNIGHT_EXPECTED_SPEC_VERSION=2000000
MIDNIGHT_EXPECTED_TRANSACTION_VERSION=4
MIDNIGHT_EXPECTED_PROOF_SERVER_VERSION=9.0.0-rc.5

# Deterministic local-development value from the standalone stack.
# It is intentionally public and must never be reused outside local testing.
MIDNIGHT_INDEXER_DEV_SECRET=303132333435363738393031323334353637383930313233343536373839303132
