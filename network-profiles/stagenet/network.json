{
  "$schema": "../../schemas/network-profile.schema.json",
  "schemaVersion": 1,
  "id": "stagenet",
  "displayName": "Midnight Stagenet 2.0",
  "mode": "hosted",
  "status": "active",
  "compatibilityLine": "v2-rc",
  "networkId": "stagenet",
  "endpoints": {
    "node": "https://rpc.stagenet.shielded.tools",
    "nodeWs": "wss://rpc.stagenet.shielded.tools",
    "indexer": "https://indexer.stagenet.shielded.tools/api/v4/graphql",
    "indexerWs": "wss://indexer.stagenet.shielded.tools/api/v4/graphql/ws",
    "proofServer": "http://127.0.0.1:6300",
    "faucet": "https://faucet.stagenet.shielded.tools",
    "explorer": "https://polkadot.js.org/apps/?rpc=wss%3A%2F%2Frpc.stagenet.shielded.tools#/explorer"
  },
  "runtime": {
    "specName": "midnight",
    "specVersion": 2000000,
    "transactionVersion": 4
  },
  "components": {
    "node": { "version": "2.0.0-rc.4", "image": "midnightntwrk/midnight-node:2.0.0-rc.4", "location": "remote" },
    "indexer": { "version": "4.4.0-pre-alpha.16", "image": "midnightntwrk/indexer-standalone:4.4.0-pre-alpha.16", "location": "remote" },
    "proofServer": { "version": "9.0.0-rc.5_experimental", "image": "midnightntwrk/proof-server:9.0.0-rc.5_experimental", "location": "local" },
    "compactCompiler": { "version": "0.33.0-rc.1", "location": "build-time" },
    "compactRuntime": { "version": "0.18.0-rc.1", "package": "@midnight-ntwrk/compact-runtime", "location": "build-time" },
    "compactJs": { "version": "2.5.5-rc.6", "package": "@midnight-ntwrk/compact-js", "location": "build-time" },
    "midnightJs": { "version": "5.0.0-beta.4", "package": "@midnight-ntwrk/midnight-js", "location": "build-time" },
    "walletSdk": { "version": "2.0.0-beta.2", "package": "@midnight-ntwrk/wallet-sdk", "location": "build-time" },
    "ledger": { "version": "9.1.0.0-rc.3", "package": "@midnightntwrk/ledger-v9", "location": "build-time" }
  },
  "capabilities": [
    "compact-contracts",
    "shielded-state",
    "unshielded-state",
    "native-tokens",
    "contract-to-contract",
    "zkir-v3",
    "contract-events",
    "keccak256",
    "secp256k1",
    "ecdsa-accounts",
    "cardano-bridge"
  ],
  "sources": [
    "https://github.com/Jalal-1/stagenet_testing/blob/main/midnight-2-0-stagenet-beta.md"
  ],
  "notes": [
    "Live node identity checked on 2026-07-15: spec 2000000, transaction version 4.",
    "ZKIR v3 requires the experimental proof-server image and an explicit compiler flag.",
    "OpenZeppelin Compact 0.3.0-alpha is not declared compatible with this v2 RC line."
  ]
}
