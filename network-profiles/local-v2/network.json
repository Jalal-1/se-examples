{
  "$schema": "../../schemas/network-profile.schema.json",
  "schemaVersion": 1,
  "id": "local-v2",
  "displayName": "Local Midnight v2 RC",
  "mode": "local",
  "status": "active",
  "compatibilityLine": "v2-rc",
  "networkId": "undeployed",
  "endpoints": {
